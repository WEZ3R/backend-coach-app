{
  "name": "coaching-app-backend",
  "version": "1.0.0",
  "description": "Backend pour application de coaching sportif",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "test": "node --test --test-concurrency=1 tests/auth.test.js tests/programs.test.js tests/sessions.test.js tests/stats.test.js tests/messages.test.js tests/requests.test.js tests/goals.test.js",
    "test:sessions": "node --test tests/sessions.test.js",
    "test:auth": "node --test tests/auth.test.js",
    "test:programs": "node --test tests/programs.test.js",
    "test:stats": "node --test tests/stats.test.js",
    "test:messages": "node --test tests/messages.test.js",
    "test:requests": "node --test tests/requests.test.js",
    "test:goals": "node --test tests/goals.test.js",
    "seed": "node prisma/seed.js",
    "seed:exercises": "node prisma/seed-exercises.js",
    "prisma:seed": "node src/prisma/seed.js",
    "db:host": "node scripts/detect-db-host.js",
    "db:backup": "cd scripts && ./export-database.sh",
    "db:restore": "cd scripts && ./import-database.sh"
  },
  "keywords": [
    "coaching",
    "fitness",
    "api"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@prisma/client": "^5.9.1",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.1",
    "express": "^4.18.2",
    "express-validator": "^7.0.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "pg": "^8.16.3",
    "rrule": "^2.8.1"
  },
  "devDependencies": {
    "node-fetch": "^3.3.2",
    "nodemon": "^3.0.3",
    "prisma": "^5.9.1",
    "xlsx": "^0.18.5"
  }
}
